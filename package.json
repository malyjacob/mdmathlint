{
  "name": "mdmathlint",
  "version": "0.4.0",
  "description": "Profile-aware Markdown math linter",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "markdown",
    "math",
    "lint",
    "remark",
    "katex"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mdmathlint": "./dist/cli.js",
    "mdmathlint-lsp": "./dist/lsp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./remark-lint": {
      "types": "./dist/remarkLint.d.ts",
      "import": "./dist/remarkLint.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "action.yml",
    ".pre-commit-hooks.yaml",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "benchmark": "node dist/benchmark.js"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "katex": "^0.16.22",
    "markdown-it": "^13.0.2",
    "markdown-it-dollarmath": "^0.5.0",
    "markdown-it-texmath": "^1.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
